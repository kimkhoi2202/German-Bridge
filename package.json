{
  "name": "german-bridge",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "dev:clean": "rm -rf .next && next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "rm -rf .next && NODE_ENV=production next build",
    "start": "NODE_ENV=production next start",
    "lint": "next lint",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 vitest run",
    "test:watch": "vitest",
    "typecheck": "rm -rf .next && tsc --noEmit",
    "ai:dataset": "tsx scripts/ai-dataset.ts",
    "ai:evaluate": "tsx scripts/ai-evaluate.ts",
    "ai:arena": "tsx scripts/ai-arena.ts",
    "ai:rating:internal": "tsx scripts/ai-rating-report.ts"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "clsx": "^2.1.1",
    "convex": "^1.38.0",
    "motion": "^12.38.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "convex-test": "^0.0.51",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
